#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INVENTORY="${1:-}"
TARGET_USER="${TARGET_USER:-${2:-}}"

if [[ -z "${INVENTORY}" || -z "${TARGET_USER}" ]]; then
  echo "用法：$0 <inventory> <target_user> [ansible-playbook 参数]"
  exit 1
fi
if [[ ! "${TARGET_USER}" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]]; then
  echo "错误：目标用户名格式不合法：${TARGET_USER}" >&2
  exit 1
fi

export ANSIBLE_CONFIG="${ROOT_DIR}/ansible/ansible.cfg"
exec ansible-playbook -i "${INVENTORY}" \
  "${ROOT_DIR}/ansible/playbooks/ubuntu-bootstrap.yml" \
  -e "target_user=${TARGET_USER}" "${@:3}"
