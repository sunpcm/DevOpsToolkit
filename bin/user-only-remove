#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
INVENTORY="${1:-}"

if [[ -z "${INVENTORY}" ]]; then
  echo "用法：$0 <inventory> [ansible-playbook 参数]"
  exit 1
fi

export ANSIBLE_CONFIG="${ROOT_DIR}/ansible/ansible.cfg"
exec ansible-playbook -i "${INVENTORY}" \
  "${ROOT_DIR}/ansible/playbooks/user-only-remove.yml" "${@:2}"
