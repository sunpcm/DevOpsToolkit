# 旧入口兼容示例。新部署优先复制 ansible/inventories/ubuntu.ini.example。
[servers]
server1 ansible_host=192.0.2.10 ansible_user=root ansible_port=22

[all:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_new_user=developer

# 密码登录不要把密码写进 inventory：
# ansible-playbook -i host.ini.examples playbook.yml --ask-pass
# 密钥登录：
# ansible-playbook -i host.ini.examples playbook.yml --private-key ~/.ssh/id_ed25519
